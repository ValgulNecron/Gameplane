                      "fontFamily": "$c:--font-primary",
                      "fontSize": 32,
                      "fontWeight": "700"
                    },
                    {
                      "type": "text",
                      "id": "utF7y",
                      "fill": "$c:--muted-foreground",
                      "textGrowth": "fixed-width",
                      "width": 700,
                      "content": "Common questions before you deploy Gameplane to your cluster.",
                      "fontFamily": "$c:--font-secondary",
                      "fontSize": 16,
                      "fontWeight": "normal"
                    },
                    {
                      "type": "frame",
                      "id": "bYZU0",
                      "width": "fill_container",
                      "gap": 32,
                      "children": [
                        {
                          "type": "frame",
                          "id": "vAuhX",
                          "width": "fill_container",
                          "layout": "vertical",
                          "gap": 16,
                          "children": [
                            {
                              "type": "frame",
                              "id": "r0h86",
                              "width": "fill_container",
                              "layout": "vertical",
                              "gap": 4,
                              "children": [
                                {
                                  "type": "text",
                                  "id": "z2xE4",
                                  "fill": "$c:--foreground",
                                  "content": "Do I need to know Kubernetes?",
                                  "fontFamily": "$c:--font-primary",
                                  "fontSize": 14,
                                  "fontWeight": "600"
                                },
                                {
                                  "type": "text",
                                  "id": "tXinY",
                                  "fill": "$c:--muted-foreground",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": "One-time cluster setup benefits from basic Helm familiarity. Day-to-day server management — console, files, backups, players — is entirely dashboard-driven; kubectl is optional.",
                                  "lineHeight": 1.5,
                                  "fontFamily": "$c:--font-secondary",
                                  "fontSize": 13,
                                  "fontWeight": "normal"
                                }
                              ]
                            },
                            {
                              "type": "frame",
                              "id": "chYml",
                              "width": "fill_container",
                              "layout": "vertical",
                              "gap": 4,
                              "children": [
                                {
                                  "type": "text",
                                  "id": "TGQg5",
                                  "fill": "$c:--foreground",
                                  "content": "Is Gameplane production-ready?",
                                  "fontFamily": "$c:--font-primary",
                                  "fontSize": 14,
                                  "fontWeight": "600"
                                },
                                {
                                  "type": "text",
                                  "id": "CrDTC",
                                  "fill": "$c:--muted-foreground",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": "It's in beta (v0.2.0-beta.3). Core workflows are feature-complete and tested, but not yet recommended for unattended production — see the Roadmap.",
                                  "lineHeight": 1.5,
                                  "fontFamily": "$c:--font-secondary",
                                  "fontSize": 13,
                                  "fontWeight": "normal"
                                }
                              ]
                            },
                            {
                              "type": "frame",
                              "id": "FvXKJ",
                              "width": "fill_container",
                              "layout": "vertical",
                              "gap": 4,
                              "children": [
                                {
                                  "type": "text",
                                  "id": "zYl2K",
                                  "fill": "$c:--foreground",
                                  "content": "Is it free?",
                                  "fontFamily": "$c:--font-primary",
                                  "fontSize": 14,
                                  "fontWeight": "600"
                                },
                                {
                                  "type": "text",
                                  "id": "dAdZr",
                                  "fill": "$c:--muted-foreground",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": "Yes. Gameplane is open-source under AGPL-3.0-or-later, with no paid tiers.",
                                  "lineHeight": 1.5,
                                  "fontFamily": "$c:--font-secondary",
                                  "fontSize": 13,
                                  "fontWeight": "normal"
                                }
                              ]
                            }
                          ]
                        },
                        {
                          "type": "frame",
                          "id": "BIKJF",
                          "width": "fill_container",
                          "layout": "vertical",
                          "gap": 16,
                          "children": [
                            {
                              "type": "frame",
                              "id": "HY7v0",
                              "width": "fill_container",
                              "layout": "vertical",
                              "gap": 4,
                              "children": [
                                {
                                  "type": "text",
                                  "id": "pjAZC",
                                  "fill": "$c:--foreground",
                                  "content": "What happens to my data if I uninstall?",
                                  "fontFamily": "$c:--font-primary",
                                  "fontSize": 14,
                                  "fontWeight": "600"
                                },
                                {
                                  "type": "text",
                                  "id": "R28rz",
                                  "fill": "$c:--muted-foreground",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": "Depends on your cluster's StorageClass reclaim policy — Gameplane doesn't force-delete PVCs itself. Back up critical data before uninstalling.",
                                  "lineHeight": 1.5,
                                  "fontFamily": "$c:--font-secondary",
                                  "fontSize": 13,
                                  "fontWeight": "normal"
                                }
                              ]
                            },
                            {
                              "type": "frame",
                              "id": "OTLgG",
                              "width": "fill_container",
                              "layout": "vertical",
                              "gap": 4,
                              "children": [
                                {
                                  "type": "text",
                                  "id": "ruxUT",
                                  "fill": "$c:--foreground",
                                  "content": "What database does it use?",
                                  "fontFamily": "$c:--font-primary",
                                  "fontSize": 14,
                                  "fontWeight": "600"
                                },
                                {
                                  "type": "text",
                                  "id": "zt9IS",
                                  "fill": "$c:--muted-foreground",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": "SQLite by default, or PostgreSQL — selectable at install time via a Helm value.",
                                  "lineHeight": 1.5,
                                  "fontFamily": "$c:--font-secondary",
                                  "fontSize": 13,
                                  "fontWeight": "normal"
                                }
                              ]
                            },
                            {
                              "type": "frame",
                              "id": "jClYF",
                              "width": "fill_container",
                              "layout": "vertical",
                              "gap": 4,
                              "children": [
                                {
                                  "type": "text",
                                  "id": "R4XgX",
                                  "fill": "$c:--foreground",
                                  "content": "Can I manage servers without the dashboard?",
                                  "fontFamily": "$c:--font-primary",
                                  "fontSize": 14,
                                  "fontWeight": "600"
                                },
                                {
                                  "type": "text",
                                  "id": "FqjLf",
                                  "fill": "$c:--muted-foreground",
                                  "textGrowth": "fixed-width",
                                  "width": "fill_container",
                                  "content": "Yes. Advanced users can bypass the API entirely and manage everything with kubectl apply — the operator is authoritative, so both stay in sync.",
                                  "lineHeight": 1.5,
                                  "fontFamily": "$c:--font-secondary",
                                  "fontSize": 13,
                                  "fontWeight": "normal"
                                }
                              ]
                            }
                          ]
                        }
                      ]
