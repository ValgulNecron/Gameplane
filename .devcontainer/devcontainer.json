{
	"name": "Kestrel",
	"image": "mcr.microsoft.com/devcontainers/base:ubuntu-24.04",
	"features": {
		"ghcr.io/devcontainers/features/common-utils:2": {
			"installZsh": "true",
			"configureZshAsDefaultShell": "false",
			"username": "vscode"
		},
		"ghcr.io/devcontainers/features/go:1": {
			"version": "1.26"
		},
		"ghcr.io/devcontainers/features/node:1": {
			"version": "20"
		},
		"ghcr.io/devcontainers/features/docker-in-docker:2": {
			"version": "latest",
			"moby": true,
			"dockerDashComposeVersion": "v2"
		},
		"ghcr.io/devcontainers/features/kubectl-helm-minikube:1": {
			"version": "1.31",
			"helm": "latest",
			"minikube": "none"
		},
		"ghcr.io/devcontainers/features/github-cli:1": {}
	},
	"runArgs": ["--init"],
	"containerEnv": {
		"GOTOOLCHAIN": "local",
		"KESTREL_REG_HOST_PORT": "5001",
		"CI": "1"
	},
	"postCreateCommand": "bash .devcontainer/post-create.sh",
	"forwardPorts": [5173, 8080, 8443, 5001, 30565],
	"portsAttributes": {
		"5173": { "label": "Vite (web dev)", "onAutoForward": "notify" },
		"8080": { "label": "Kestrel ingress (HTTP)", "onAutoForward": "silent" },
		"8443": { "label": "Kestrel ingress (HTTPS)", "onAutoForward": "silent" },
		"5001": { "label": "Local OCI registry", "onAutoForward": "silent" },
		"30565": { "label": "Sample Minecraft NodePort", "onAutoForward": "silent" }
	},
	"remoteUser": "vscode",
	"customizations": {
		"vscode": {
			"extensions": [
				"golang.go",
				"dbaeumer.vscode-eslint",
				"esbenp.prettier-vscode",
				"bradlc.vscode-tailwindcss",
				"ms-kubernetes-tools.vscode-kubernetes-tools",
				"redhat.vscode-yaml",
				"tamasfe.even-better-toml"
			],
			"settings": {
				"go.toolsManagement.checkForUpdates": "off",
				"go.useLanguageServer": true,
				"editor.formatOnSave": true,
				"[go]": {
					"editor.defaultFormatter": "golang.go"
				},
				"[typescript]": {
					"editor.defaultFormatter": "esbenp.prettier-vscode"
				},
				"[typescriptreact]": {
					"editor.defaultFormatter": "esbenp.prettier-vscode"
				}
			}
		}
	}
}
