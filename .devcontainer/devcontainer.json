{
	"name": "Gameplane",
	"image": "mcr.microsoft.com/devcontainers/base:ubuntu-24.04",
	"features": {
		"ghcr.io/devcontainers/features/common-utils:2": {
			"installZsh": "true",
			"configureZshAsDefaultShell": "false",
			"username": "vscode"
		},
		"ghcr.io/devcontainers/features/go:1": {
			"version": "1.26"
		},
		"ghcr.io/devcontainers/features/node:1": {
			"version": "20"
		},
		"ghcr.io/devcontainers/features/docker-in-docker:2": {
			"version": "latest",
			"moby": true,
			"dockerDashComposeVersion": "v2"
		},
		"ghcr.io/devcontainers/features/kubectl-helm-minikube:1": {
			"version": "1.31",
			"helm": "latest",
			"minikube": "none"
		},
		"ghcr.io/devcontainers/features/github-cli:1": {}
	},
	"runArgs": ["--init"],
	"containerEnv": {
		"GOTOOLCHAIN": "local",
		"GAMEPLANE_REG_HOST_PORT": "5001",
		"CI": "1"
	},
	"postCreateCommand": "bash .devcontainer/post-create.sh",
	"forwardPorts": [5173, 8080, 8443, 5001, 30565],
	"portsAttributes": {
		"5173": { "label": "Vite (web dev)", "onAutoForward": "notify" },
		"8080": { "label": "Gameplane ingress (HTTP)", "onAutoForward": "silent" },
		"8443": { "label": "Gameplane ingress (HTTPS)", "onAutoForward": "silent" },
		"5001": { "label": "Local OCI registry", "onAutoForward": "silent" },
		"30565": { "label": "Sample Minecraft NodePort", "onAutoForward": "silent" }
	},
	"remoteUser": "vscode",
	"customizations": {
		"vscode": {
			"extensions": [
				"golang.go",
				"dbaeumer.vscode-eslint",
				"esbenp.prettier-vscode",
				"bradlc.vscode-tailwindcss",
				"ms-kubernetes-tools.vscode-kubernetes-tools",
				"redhat.vscode-yaml",
				"tamasfe.even-better-toml",
				"anthropic.claude-code",
				"google.geminicodeassist",
				"google.gemini-cli-vscode-ide-companion",
				"highagency.pencildev",
				"ms-azuretools.vscode-containers",
				"ms-vscode.makefile-tools",
				"fill-labs.dependi",
				"rust-lang.rust-analyzer",
				"dustypomerleau.rust-syntax",
				"1yib.rust-bundle",
				"vue.volar",
				"nicolasdschmidt.lunar-pink",
				"ahmedsaid.darkpinkpro"
			],
			"settings": {
				"go.toolsManagement.checkForUpdates": "off",
				"go.useLanguageServer": true,
				"editor.formatOnSave": true,
				"[go]": {
					"editor.defaultFormatter": "golang.go"
				},
				"[typescript]": {
					"editor.defaultFormatter": "esbenp.prettier-vscode"
				},
				"[typescriptreact]": {
					"editor.defaultFormatter": "esbenp.prettier-vscode"
				},
				"workbench.colorTheme": "Lunar Pink",
				"workbench.browser.openLocalhostLinks": false,
				"vs-kubernetes": {
					"vs-kubernetes.crd-code-completion": "enabled"
				}
			}
		}
	}
}
