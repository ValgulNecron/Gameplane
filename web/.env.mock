# Loaded by `vite --mode mock`. Used by Playwright's mock-mode webServer
# to opt the SPA into the MSW worker. main.tsx checks
# import.meta.env.VITE_E2E_MOCK at startup; vite-builtins like
# import.meta.env.MODE come from --mode and don't need a file.
#
# This file is intentionally checked in — it's e2e-only and contains no
# secrets.

VITE_E2E_MOCK=true
